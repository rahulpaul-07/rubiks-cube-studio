{
  "name": "rubiks-cube-studio",
  "version": "1.0.0",
  "description": "Interactive 3x3 Rubik's Cube editor and solver built with TypeScript and Three.js",
  "author": "Rahul Paul",
  "repository": {
    "type": "git",
    "url": "https://github.com/rahulpaul-07/rubiks-cube-studio.git"
  },
  "keywords": [
    "rubiks-cube",
    "threejs",
    "typescript",
    "solver",
    "kociemba"
  ],
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10.8.2"
  },
  "packageManager": "npm@11.9.0",
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run test:e2e && npm run build",
    "dev": "vite --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build": "tsc && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "cubejs": "1.1.0",
    "lucide": "^1.20.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{ts,js,html,css,md,json}": "prettier --write",
    "*.ts": "eslint --fix"
  }
}
